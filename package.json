{
  "name": "openmv",
  "displayName": "OpenMV",
  "description": "%openmv.description%",
  "version": "2.5.0",
  "packageManager": "pnpm@11.0.9",
  "publisher": "singtown",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/SingTown/openmv-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/openmv.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openmv.connect",
        "title": "%openmv.command.connect.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.disconnect",
        "title": "%openmv.command.disconnect.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.runScript",
        "title": "%openmv.command.runScript.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.stopScript",
        "title": "%openmv.command.stopScript.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.drive",
        "title": "%openmv.command.drive.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.selectFrameSaveFolder",
        "title": "%openmv.command.selectFrameSaveFolder.title%",
        "category": "OpenMV",
        "icon": "$(folder)"
      },
      {
        "command": "openmv.saveFrame",
        "title": "%openmv.command.saveFrame.title%",
        "category": "OpenMV",
        "icon": "$(save)"
      },
      {
        "command": "openmv.update",
        "title": "%openmv.command.update.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.firmware",
        "title": "%openmv.command.firmware.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.repair",
        "title": "%openmv.command.repair.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.openExample",
        "title": "%openmv.command.openExample.title%",
        "category": "OpenMV"
      },
      {
        "command": "openmv.searchExample",
        "title": "%openmv.command.searchExample.title%",
        "category": "OpenMV",
        "icon": "$(search)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openmv-activitybar",
          "title": "OpenMV",
          "icon": "media/openmv.svg"
        }
      ]
    },
    "views": {
      "openmv-activitybar": [
        {
          "id": "openmv-frameView",
          "name": "%openmv.view.frame.name%",
          "type": "webview"
        },
        {
          "id": "openmv-exampleView",
          "name": "%openmv.view.examples.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "openmv.selectFrameSaveFolder",
          "when": "view == openmv-frameView",
          "group": "navigation@1"
        },
        {
          "command": "openmv.saveFrame",
          "when": "view == openmv-frameView",
          "group": "navigation@2"
        },
        {
          "command": "openmv.searchExample",
          "when": "view == openmv-exampleView",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "openmv.openExample",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "build": "pnpm run typecheck && node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/ && pnpm run typecheck",
    "package": "vsce package",
    "package:darwin-arm64": "vsce package --no-dependencies --target darwin-arm64 --ignoreFile .vscodeignore.darwin-arm64",
    "package:win32-x64": "vsce package --no-dependencies --target win32-x64 --ignoreFile .vscodeignore.win32",
    "package:win32-arm64": "vsce package --no-dependencies --target win32-arm64 --ignoreFile .vscodeignore.win32",
    "package:linux-x64": "vsce package --no-dependencies --target linux-x64 --ignoreFile .vscodeignore.linux-x64",
    "package:linux-arm64": "vsce package --no-dependencies --target linux-arm64 --ignoreFile .vscodeignore.linux-arm64",
    "package:all": "pnpm run package:darwin-arm64 && pnpm run package:win32-x64 && pnpm run package:win32-arm64 && pnpm run package:linux-x64 && pnpm run package:linux-arm64",
    "package:pre-release:darwin-arm64": "vsce package --pre-release --no-dependencies --target darwin-arm64 --ignoreFile .vscodeignore.darwin-arm64",
    "package:pre-release:win32-x64": "vsce package --pre-release --no-dependencies --target win32-x64 --ignoreFile .vscodeignore.win32",
    "package:pre-release:win32-arm64": "vsce package --pre-release --no-dependencies --target win32-arm64 --ignoreFile .vscodeignore.win32",
    "package:pre-release:linux-x64": "vsce package --pre-release --no-dependencies --target linux-x64 --ignoreFile .vscodeignore.linux-x64",
    "package:pre-release:linux-arm64": "vsce package --pre-release --no-dependencies --target linux-arm64 --ignoreFile .vscodeignore.linux-arm64",
    "package:all:pre-release": "pnpm run package:pre-release:darwin-arm64 && pnpm run package:pre-release:win32-x64 && pnpm run package:pre-release:win32-arm64 && pnpm run package:pre-release:linux-x64 && pnpm run package:pre-release:linux-arm64"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17",
    "execa": "^9.6.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  }
}
